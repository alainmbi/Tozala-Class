{
  "extends": "@adonisjs/tsconfig/tsconfig.client.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "paths": {
      "@generated/registry": ["./types/generated-registry.d.ts"],
      "~/*": ["./*"],
      "@generated/*": ["../../.adonisjs/client/*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
