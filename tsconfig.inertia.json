/**
 * This file only exists to avoid the circular reference between the Inertia
 * codebase and the backend codebase, which takes place because of the
 * codegen. We have Inertia app referencing backend code and backend
 * code referencing Inertia pages for inferring props types.
 *
 * The main part here is "composite: true"
 */
{
  "extends": "./resources/js/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./resources/js",
    "composite": true
  },
  "include": ["./resources/js/**/*.ts", "./resources/js/**/*.tsx"]
}
